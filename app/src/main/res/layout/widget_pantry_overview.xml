<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_pantry_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mi despensa"
        android:textColor="#1F120A"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_pantry_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="No hay cafés en despensa. Toca para abrir y añadir."
        android:textColor="#6A4D3B"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/widget_pantry_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_pantry_item_title_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="#3E2618"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_pantry_item_grams_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#7A6253"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/widget_pantry_item_progress_1"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#8F4B22" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_pantry_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_pantry_item_title_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="#3E2618"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_pantry_item_grams_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#7A6253"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/widget_pantry_item_progress_2"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#8F4B22" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_pantry_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_pantry_item_title_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="#3E2618"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_pantry_item_grams_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#7A6253"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/widget_pantry_item_progress_3"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#8F4B22" />
    </LinearLayout>
</LinearLayout>
