<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_pantry_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mi despensa"
        android:textColor="#1F120A"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_pantry_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Sin cafés en la despensa"
        android:textColor="#6A4D3B"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/widget_pantry_card_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/widget_pantry_item_card"
                android:orientation="vertical"
                android:padding="6dp"
                android:visibility="invisible">

                <ImageView
                    android:id="@+id/widget_pantry_item_image_1"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_launcher_foreground"
                    android:scaleType="centerInside" />

                <TextView
                    android:id="@+id/widget_pantry_item_name_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:textColor="#2E2017"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_pantry_item_brand_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:textColor="#7A6253"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_pantry_item_stock_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#5C4334"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/widget_pantry_item_progress_1"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="4dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/widget_progress_brown" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_pantry_card_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/widget_pantry_item_card"
                android:orientation="vertical"
                android:padding="6dp"
                android:visibility="invisible">

                <ImageView android:id="@+id/widget_pantry_item_image_2" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_launcher_foreground" android:scaleType="centerInside" />
                <TextView android:id="@+id/widget_pantry_item_name_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:maxLines="1" android:textColor="#2E2017" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/widget_pantry_item_brand_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLines="1" android:textColor="#7A6253" android:textSize="10sp" />
                <TextView android:id="@+id/widget_pantry_item_stock_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="#5C4334" android:textSize="10sp" android:textStyle="bold" />
                <ProgressBar android:id="@+id/widget_pantry_item_progress_2" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="4dp" android:max="100" android:progress="0" android:progressDrawable="@drawable/widget_progress_brown" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/widget_pantry_card_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/widget_pantry_item_card"
                android:orientation="vertical"
                android:padding="6dp"
                android:visibility="invisible">

                <ImageView android:id="@+id/widget_pantry_item_image_3" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_launcher_foreground" android:scaleType="centerInside" />
                <TextView android:id="@+id/widget_pantry_item_name_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:maxLines="1" android:textColor="#2E2017" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/widget_pantry_item_brand_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLines="1" android:textColor="#7A6253" android:textSize="10sp" />
                <TextView android:id="@+id/widget_pantry_item_stock_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="#5C4334" android:textSize="10sp" android:textStyle="bold" />
                <ProgressBar android:id="@+id/widget_pantry_item_progress_3" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="4dp" android:max="100" android:progress="0" android:progressDrawable="@drawable/widget_progress_brown" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_pantry_card_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/widget_pantry_item_card"
                android:orientation="vertical"
                android:padding="6dp"
                android:visibility="invisible">

                <ImageView android:id="@+id/widget_pantry_item_image_4" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_launcher_foreground" android:scaleType="centerInside" />
                <TextView android:id="@+id/widget_pantry_item_name_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:maxLines="1" android:textColor="#2E2017" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/widget_pantry_item_brand_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLines="1" android:textColor="#7A6253" android:textSize="10sp" />
                <TextView android:id="@+id/widget_pantry_item_stock_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:textColor="#5C4334" android:textSize="10sp" android:textStyle="bold" />
                <ProgressBar android:id="@+id/widget_pantry_item_progress_4" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="4dp" android:max="100" android:progress="0" android:progressDrawable="@drawable/widget_progress_brown" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_pantry_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#7A6253"
        android:textSize="11sp"
        android:visibility="gone" />

</LinearLayout>
