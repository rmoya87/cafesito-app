            <TextView android:id="@+id/widget_bar_water_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#2D77AE" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_label_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#705747" android:textSize="9sp" />
        </LinearLayout>
