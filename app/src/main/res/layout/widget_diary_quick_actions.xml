<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_diary_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mi diario"
        android:textColor="#1F120A"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_diary_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="0 mg cafeína · 0 ml agua"
        android:textColor="#6A4D3B"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_filter_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_chip_background"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:text="• DÍA"
            android:textColor="#5A3826"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_filter_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_chip_background"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:text="SEM"
            android:textColor="#5A3826"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_filter_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_chip_background"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:text="MES"
            android:textColor="#5A3826"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Cafeína y agua"
        android:textColor="#6A4D3B"
        android:textSize="10sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/widget_bar_coffee_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#8F4B22" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_water_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#2D77AE" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_label_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#705747" android:textSize="9sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/widget_bar_coffee_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#8F4B22" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_water_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#2D77AE" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_label_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#705747" android:textSize="9sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/widget_bar_coffee_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#8F4B22" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_water_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#2D77AE" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_label_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#705747" android:textSize="9sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/widget_bar_coffee_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#8F4B22" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_water_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#2D77AE" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_label_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#705747" android:textSize="9sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/widget_bar_coffee_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#8F4B22" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_water_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#2D77AE" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_label_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#705747" android:textSize="9sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/widget_bar_coffee_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#8F4B22" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_water_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#2D77AE" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_label_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#705747" android:textSize="9sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/widget_bar_coffee_7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#8F4B22" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_water_7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▁" android:textColor="#2D77AE" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_bar_label_7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#705747" android:textSize="9sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
