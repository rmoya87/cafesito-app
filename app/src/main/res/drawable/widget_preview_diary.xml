<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo del Widget -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#E8D4C2" />
        </shape>
    </item>

    <!-- Título "Mi diario" -->
    <item android:left="16dp" android:top="16dp" android:right="160dp">
        <shape android:shape="rectangle">
            <size android:height="10dp"/>
            <solid android:color="#1F120A"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>

    <!-- Resumen "mg · ml" -->
    <item android:left="16dp" android:top="32dp" android:right="100dp">
        <shape android:shape="rectangle">
            <size android:height="6dp"/>
            <solid android:color="#6A4D3B"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>

    <!-- Representación de Gráfico de Barras -->
    <item android:left="16dp" android:top="50dp" android:right="16dp" android:bottom="60dp">
        <layer-list>
            <!-- Barra 1 -->
            <item android:left="10dp" android:right="180dp" android:top="20dp">
                <shape android:shape="rectangle"><solid android:color="#7E4422"/><corners android:radius="1dp"/></shape>
            </item>
            <item android:left="20dp" android:right="170dp" android:top="10dp">
                <shape android:shape="rectangle"><solid android:color="#2196F3"/><corners android:radius="1dp"/></shape>
            </item>
            <!-- Barra 2 -->
            <item android:left="40dp" android:right="150dp" android:top="15dp">
                <shape android:shape="rectangle"><solid android:color="#7E4422"/><corners android:radius="1dp"/></shape>
            </item>
            <item android:left="50dp" android:right="140dp" android:top="5dp">
                <shape android:shape="rectangle"><solid android:color="#2196F3"/><corners android:radius="1dp"/></shape>
            </item>
            <!-- Barra 3 -->
            <item android:left="70dp" android:right="120dp" android:top="25dp">
                <shape android:shape="rectangle"><solid android:color="#7E4422"/><corners android:radius="1dp"/></shape>
            </item>
            <item android:left="80dp" android:right="110dp" android:top="15dp">
                <shape android:shape="rectangle"><solid android:color="#2196F3"/><corners android:radius="1dp"/></shape>
            </item>
            <!-- Barra 4 -->
            <item android:left="100dp" android:right="90dp" android:top="10dp">
                <shape android:shape="rectangle"><solid android:color="#7E4422"/><corners android:radius="1dp"/></shape>
            </item>
            <item android:left="110dp" android:right="80dp" android:top="0dp">
                <shape android:shape="rectangle"><solid android:color="#2196F3"/><corners android:radius="1dp"/></shape>
            </item>
        </layer-list>
    </item>

    <!-- Botones de Acción inferiores -->
    <item android:left="16dp" android:bottom="16dp" android:right="110dp">
        <shape android:shape="rectangle">
            <size android:height="30dp"/>
            <solid android:color="#7E4422"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item android:left="110dp" android:bottom="16dp" android:right="16dp">
        <shape android:shape="rectangle">
            <size android:height="30dp"/>
            <solid android:color="#2196F3"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</layer-list>
