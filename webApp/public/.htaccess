# Ionos / Apache: SPA + servir estáticos sin 500
# Copiado a la raíz de dist en el build (Vite copia public/ a dist/)
# Hosting: los ficheros están en /cafesito-web/app y el dominio (cafesitoapp.com) tiene
# esa carpeta como document root. Por tanto RewriteBase / es correcto (raíz = carpeta app).
# ErrorDocument 404: para rutas SPA inexistentes, servir el shell desde raíz.
ErrorDocument 404 /index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # favicon.ico → logo.png (evita 500 si el navegador pide /favicon.ico)
  RewriteRule ^favicon\.ico$ /logo.png [L]
  # No reescribir peticiones a assets ni a ficheros estáticos (evita 500)
  RewriteRule ^assets/ - [L]
  RewriteRule ^registerSW\.js$ - [L]
  # SEO: robots + todos los sitemaps (índice sitemap.xml / sitemap.xml.gz, parciales sitemap-*.xml,
  # image-sitemap*.xml, sitemap-coffee-*.xml, etc.) — mismo criterio que dist/ tras update-sitemap-from-supabase.mjs
  RewriteRule ^robots\.txt$ - [L]
  RewriteRule ^sitemap\.xml(\.gz)?$ - [L]
  RewriteRule ^sitemap-.*\.xml(\.gz)?$ - [L]
  RewriteRule ^image-sitemap.*\.xml(\.gz)?$ - [L]
  RewriteRule \.(js|css|png|svg|ico|webmanifest|woff2?|xml|gz)$ - [L]

  # --- Canonical: sin "/" final (SEO) ---
  # Nota: servimos rutas prerender como fichero index.html para evitar el auto-redirect de Apache a "/".

  # /landing/ -> /landing (301) y servir la landing sin slash
  RewriteRule ^landing/$ /landing [R=301,L]
  RewriteRule ^landing$ /landing/index.html [L]
  RewriteRule ^landing/ - [L]

  # /coffee/<slug>/ -> /coffee/<slug> (301) y servir prerender sin slash
  RewriteRule ^coffee/([^/]+)/$ /coffee/$1 [R=301,L]
  RewriteRule ^coffee/([^/]+)$ /coffee/$1/index.html [L]

  # Quitar "/" final en el resto (excepto raíz). Solo si NO es fichero/directorio real.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+?)/$ /$1 [R=301,L]

  # No reescribir si existe un fichero o directorio
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ /index.html [L]
</IfModule>

# Tipos MIME para que el servidor sirva bien los estáticos
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
  AddType application/manifest+json .webmanifest
  AddType image/png .png
  AddType image/svg+xml .svg
  AddType application/xml .xml
  AddType application/gzip .gz
</IfModule>

# Que el navegador no cachee index.html ni el service worker: cada deploy se ve al instante
<IfModule mod_headers.c>
  # SW y runtime críticos: no cache
  <FilesMatch "sw\.js|registerSW\.js|workbox-.*\.js|workbox-.*\.mjs">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # App shell (index raíz): cache corto para revalidar rápido
  <If "%{REQUEST_URI} == '/' || %{REQUEST_URI} == '/index.html'">
    Header set Cache-Control "public, max-age=300, stale-while-revalidate=30"
  </If>

  # Rutas SEO indexables (coffee): cache largo + stale-while-revalidate
  <If "%{REQUEST_URI} =~ m#^/coffee/[^/]+$#">
    Header set Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
  </If>

  # Rutas medias (search/login/facetas): cache medio
  <If "%{REQUEST_URI} =~ m#^/(search|login)(/.*)?$#">
    Header set Cache-Control "public, max-age=3600, stale-while-revalidate=86400"
  </If>

  # Assets compilados: muy largo
  <FilesMatch "^assets/.*\.(js|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache fuerte para OG images (versionadas por deploy / por id)
  <FilesMatch "^og/.*\.(jpg|jpeg|png|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

