# Copia a .env y sustituye con los valores de tu proyecto en Supabase → Settings → API.
# Si ves "your_project.supabase.co" al hacer login, tu .env tiene el placeholder: usa la URL real y reinicia npm run dev.
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcional: Client ID de Google (tipo "Aplicación web") para el botón personalizado "Iniciar sesión con Google"
# con nombre/email del usuario. Mismo ID que en Supabase → Authentication → Providers → Google.
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Solo para desarrollo local: botón "Entrar como usuario 1924119502". Supabase → Settings → API → service_role (secret).
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
