# Copiar a .env y ajustar si hace falta. .env no se sube a git.

# Google Tag Manager — contenedor web (WebApp). Analíticas van solo por GTM (GA4 se configura en el contenedor).
VITE_GTM_CONTAINER_ID=GTM-WLXN93VK

# Tour por pestañas: "false" u "0" oculta el overlay (paridad con Gradle APP_TAB_TOUR_V1_ENABLED en Android).
# VITE_APP_TAB_TOUR_V1_ENABLED=true
