# Copia a .env y sustituye con los valores de tu proyecto en Supabase → Settings → API.
# Si ves "your_project.supabase.co" al hacer login, tu .env tiene el placeholder: usa la URL real y reinicia npm run dev.
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

